{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "lib": ["dom", "es2017"],
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": "./",
    "resolveJsonModule": true,
    "paths": {
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@utils/*": ["src/utils/*"],
      "@styles/*": ["src/styles/*"],
      "@platforms/*": ["src/platforms/*"],
      "@wasm/*": ["src/wasm/*"],
      "@versioning/*": ["src/versioning/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": ["src", "sample", "config", "src/global.d.ts"]
}
