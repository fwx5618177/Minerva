{
  "name": "minerva",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "release": "standard-version",
    "build:lib": "BUILD_TARGET=lib vite build",
    "build": "BUILD_TARGET vite build",
    "dev": "vite",
    "serve": "vite preview",
    "format": "prettier --write 'src/**/*.{ts,tsx,scss}'",
    "lint": "eslint \"{src,sample}/**/*.{js,ts,tsx}\"",
    "test": "jest --config .jest.config.js --no-cache",
    "test:update": "jest --config .jest.config.js --no-cache --update-snapshot",
    "test:coverage": "jest test --coverage",
    "docs:build": "gitbook build docs",
    "docs:serve": "gitbook serve docs",
    "clean:cache": "rimraf src/dist src/**/dist src/**/**/dist sample/dist sample/**/dist sample/**/**/dist config/dist config/**/dist config/**/**/dist",
    "clean": "rimraf dist lib node_modules"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "i18next": "^23.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0",
    "react-icons": "^5.2.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.8",
    "@babel/plugin-transform-runtime": "^7.24.7",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.8.0",
    "@types/enzyme": "^3.10.18",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "@vitejs/plugin-react": "^4.3.1",
    "babel-jest": "^27.5.1",
    "babel-plugin-transform-rename-import": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "gitbook-cli": "^2.3.2",
    "husky": "^9.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "sass": "^1.77.8",
    "standard-version": "^9.5.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "{src,sample}/**/*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}