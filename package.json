{
  "name": "minerva",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "release": "standard-version",
    "build:lib": "BUILD_TARGET=lib vite build",
    "build": "BUILD_TARGET vite build",
    "dev": "vite",
    "serve": "vite preview",
    "test": "jest --coverage",
    "docs:build": "gitbook build docs",
    "docs:serve": "gitbook serve docs",
    "clean:cache": "rimraf src/dist src/**/dist src/**/**/dist sample/dist sample/**/dist sample/**/**/dist config/dist config/**/dist config/**/**/dist",
    "clean": "rimraf dist lib node_modules"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "i18next": "^23.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0",
    "react-icons": "^5.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.7.0",
    "gitbook-cli": "^2.3.2",
    "husky": "^9.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "sass": "^1.77.8",
    "standard-version": "^9.5.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.tsx": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}